{
  "name": "the-engine",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "build-json": "cd functions && pnpm build-json",
    "build-models": "cd functions && pnpm build-models",
    "build-docs": "cd apps/tools/documentation && pnpm build-docusaurus-openapi",
    "update-schema": "pnpm build-json && pnpm build-models && pnpm build-docs",
    "build-openapi-docs": "cd functions && pnpm build-json && cd ../apps/tools/documentation && pnpm build-docusaurus-openapi"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "turbo": "^2.8.19",
    "typescript": "5.7.3"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "debounce": "^2.2.0",
    "react-icons": "^5.6.0"
  }
}
